# ---- Calliope IDE - Docker Environment Variables ----
# Copy this file to .env before running docker-compose:
#   cp .env.docker .env
# Then update the values below.

# ---- Frontend ----
FRONTEND_PORT=3000

# ---- Backend ----
BACKEND_PORT=5000
FLASK_ENV=production

# ---- Security (CHANGE THESE!) ----
SECRET_KEY=generate-a-strong-random-secret-key
JWT_SECRET_KEY=generate-a-different-strong-random-key

# ---- JWT Token Expiration (seconds) ----
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ---- AI Agent ----
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
