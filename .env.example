# Server Configuration
PORT=5000
FLASK_ENV=development
APP_ENV=development

# Frontend Runtime
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_ENV=development

# Database
DATABASE_URL=sqlite:///data/calliope.db

# Security Keys (REQUIRED - Generate using the command below)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=

# JWT Token Expiration (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Gemini API (for AI agent)
GEMINI_API_KEY=your-gemini-api-key-here

# Observability (Production-grade monitoring)
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Enable JSON structured logging for ELK/CloudWatch integration
ENABLE_STRUCTURED_LOGGING=true
